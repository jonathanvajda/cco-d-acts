############################
#   Classes
############################

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000001> (Document Act Input Document)

AnnotationAssertion(rdfs:comment <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "Originally a subclass of document (a subclass of Information Content Entity). Since it takes an input, Information Bearing Artifact is a better genus."@en)
AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "Document Act Input Document"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "A Document that is intended to be the specified input in a Deontic Document Act. It has a Plan Specification as a part that specifies the intended socio-legal entities that are created through the document (objective specification) and the way in which the Deontic Document Act is to be performed (by signing, by stamping, etc.) (action specification)."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "A loan application form that is not yet filled with personal and financial information."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "A marriage license that is intended to be used in the documented solemnization of marital vows."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "An informed consent form that is intended to have a subject's PII data fields filled in."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "Modified, originally from Mathias Brochhausen (D-Acts Ontology), http://purl.obolibrary.org/obo/IAO_0021007"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000001> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000001> <https://www.commoncoreontologies.org/ont00001298>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000003> (Standing Declaration)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "Standing Declaration"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "enactment"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "A social act that postulates a socio-legal fact for a specified group of people or organizations."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "A verbal utterance to obligate oneself to take care of a neighbor's pet animal."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "A written document to permit some person to reside in exchange for a fee."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "Modified, originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021102"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000003> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000003> <https://www.commoncoreontologies.org/ont00001327>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000004> (Deontic Role)

AnnotationAssertion(rdfs:comment <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "This definition attempts to capture \"A role that inheres in an agent and which is externally grounded in the normative expectations that other agents within a social context have concerning how that agent should behave.\" (D-Acts, IAO_0021008) In an effort to be more CCO-conformant, I have followed similar recommendations as Eric Merrell et al. (2021), omitting their condition that the agent must be a member of that group of agents."@en)
AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "Deontic Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "A Role that inheres in an Agent and which is externally grounded in the normative expectations of some Group of Agents concerning how that Agent should behave."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "Legal judge role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "Mandatory reporter role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "President role"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "Modified; originally from Mathias Brochhausen & Neil Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021008 ('deontic role')"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000004> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000004> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000005> (Deontic Declaration)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "Deontic Declaration"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "A Social Act that creates, revokes, or modifies a Deontic Role."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "Oath to speak the truth on the witness stand in a court of law"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "Permission for a surgeon to perform a hysterectomy"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "Pronouncement of knighthood"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "Modified, originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021009 . Equivalent to some Social Act that either 'legally revokes' some 'deontic role' OR 'has_specified_output' some 'deontic role'"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000005> "Jonathan M. Vajda"@en)
EquivalentClasses(<https://github.com/jonathanvajda/cco-d-acts/ont00000005> ObjectIntersectionOf(<https://www.commoncoreontologies.org/ont00001327> ObjectUnionOf(ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000299> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>) ObjectSomeValuesFrom(<https://github.com/jonathanvajda/cco-d-acts/ont00000017> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>))))
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000005> <https://www.commoncoreontologies.org/ont00001327>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000006> (Deontic Document Act)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "Deontic Document Act"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "A Deontic Declaration that creates, revokes, or modifies a Deontic Role by legitimately manipulating (signing, stamping, publishing) a Document"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "Attestation of degree conferral by means of a diploma"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "Issuance of a citation that an individual has violated a legal regulation"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "my filling in an immigration form, a judge's signing and stamping a court order (Mathias Brochhausen)"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "Modified, originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021001 .Their class is a defined class, equivalent to some Deontic Declaration that 'has_specified_input' some 'document act input document' AND 'has_specified_output' some 'document'"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000006> "Jonathan M. Vajda"@en)
EquivalentClasses(<https://github.com/jonathanvajda/cco-d-acts/ont00000006> ObjectIntersectionOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000005> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000293> <https://github.com/jonathanvajda/cco-d-acts/ont00000001>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000299> <https://www.commoncoreontologies.org/ont00001298>)))
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000006> <https://github.com/jonathanvajda/cco-d-acts/ont00000005>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000007> (Act of Authentication)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000007> "Act of Authentication"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://github.com/jonathanvajda/cco-d-acts/ont00000007> "Authentication"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000007> "An Intentional Act that verifies the legitimacy and truth value of some identity claim, whether that claim was given explicitly or implicitly"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000007> "I order a beer and the bartender authenticates my age by looking at my DOB on my driver's license. I sign into my email account, and the system authenticates my permission to read the email by checking the password I enter against my password listed in the database. (Amanda Hicks)"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000007> "Modified, originally from Amanda Hicks (D-Acts), http://purl.obolibrary.org/obo/IAO_0020023. Originally came with axioms: BFO_0000015 and (realizes some 'credential role') and (BFO_0000057 some IAO_0000027) and (BFO_0000057 some ( inverse (IAO_0000136) some IAO_0000027))"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000007> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000007> <https://www.commoncoreontologies.org/ont00000228>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000008> (Claimant Role)

AnnotationAssertion(rdfs:comment <https://github.com/jonathanvajda/cco-d-acts/ont00000008> "Comment from source: Claimant roles can either be discharged by one act of fulfilling a duty (e.g. when I pay back $5 owed to a friend) or they can remain intact and require ongoing adhering to a duty. https://plato.stanford.edu/entries/rights/#FormRighHohfAnalSyst discuss the claim of a child to freedom from abuse. That claim remains in existence and the duty to not abuse the child needs to be continuously be acted upon, by a multitude of agents (which all have a duty holder role). This claim is mutually dependent on the duty to abstain from abusing the child."@en)
AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000008> "Claimant Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000008> "A Deontic Role that inheres in an Agent A, that mutually depends on the existence of a Duty Holder Role borne by Agent B, and that specifies B performaing or abstaining from some Act C, or providing or surrendering some Continuant D to A."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000008> "Modified, originally from Brochhausen and Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021013 which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000008> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000008> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000009> (Duty Holder Role)

AnnotationAssertion(rdfs:comment <https://github.com/jonathanvajda/cco-d-acts/ont00000009> "Comment from source: Claimant roles can either be discharged by one act of fulfilling a duty (e.g. when I pay back $5 owed to a friend) or they can remain intact and require ongoing adhering to a duty. https://plato.stanford.edu/entries/rights/#FormRighHohfAnalSyst discuss the claim of a child to freedom from abuse. That claim remains in existence and the duty to not abuse the child needs to be continuously be acted upon, by a multitude of agents (which all have a duty holder role). This claim is mutually dependent on the duty to abstain from abusing the child."@en)
AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000009> "Duty Holder Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000009> "A Deontic Role that inheres in an Agent A, that mutually depends on the existence of a Claimant Role borne by Agent B, and that specifies A performing or abstaining from some Act C, or providing or surrendering some Continuant D to B."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000009> "Modified, originally from Brochhausen and Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021016 ('duty holder role') which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000009> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000009> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000010> (Deontic Power Role)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "Deontic Power Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "A Deontic Role that, if realized, is realized by its bearer's creating, revoking, or modifying some Deontic Role."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "Employer role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "Governor role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "Legal judge role"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "Modified, originally from Mathias Brochhausen & J. Neil Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021023 ('power role')"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000010> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000010> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000011> (Privilege Holder Role)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000011> "Privilege Holder Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000011> "A Deontic Role that inheres in an Agent A, that specifies that no Agent B bears a Claimant Role against A performing Act C."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000011> "Modified; originally from Mathias Brochhausen and J. Neil Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021019 which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000011> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000011> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000012> (Document Act Performer Role)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000012> "Document Act Performer Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000012> "A Role inhering in an Agent (either a human, an organization, or an aggregate of either) that is realized by the bearer being an agent (initiating participant) in a Document Act."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000012> "a judge's role of signing a court order"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000012> "Modified; originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021031"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000012> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000012> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000013> (Document Act Template Creator Role)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000013> "Document Act Template Creator Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000013> "A Role that inheres in an Agent (a human, organization, or aggregate of these) that is realized in preparing a Document that is the specified input to a Document Act and is the Input Document of a Document Act."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000013> "The role of the U.S. Citizenship and Immigration Service realized by the creation of an immigration form that is being filled in, the role of a national professional association realized by the creation of a clinical guideline that is to be certified"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000013> "Modified; originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021021"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000013> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000013> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000014> (Deontic Declaration Performer Role)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000014> "Deontic Declaration Performer Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000014> "A Role inhering in an Agent or Aggregate of Agents that is realized by the bearer being the active participant (agent in) a Deontic Declaration."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000014> "Modified; originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021022 . Originally a subclass of BFO_0000023 ('role'), but this is clearly a subclass of deontic role."@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000014> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000014> <https://github.com/jonathanvajda/cco-d-acts/ont00000004>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000015> (Credential Role)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000015> "Credential Role"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000015> "A Role that inheres in an Identification Artifact and is realized by some Act of Authentication process."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000015> "A passport's role for an act of authentication for boarding an international flight"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000015> "A server's role in an authentication into an online banking system"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000015> "Modified; originally by Amanda Hicks (D-Acts), http://purl.obolibrary.org/obo/IAO_0020024. See the notes on 'Identification Artifact', which clarifies why 'Identity Document' is significantly corrected and why 'documented identity' is obviated. Original definition 'A role that inheres in a concretization of an identity document and is realized by an authentication process.' Equivalent class is adjusted, since 'identity document' is not an ICE but rather artifact IBE. Originally: to BFO_0000023[role] and (RO_0000054[realized in] some authentication) and (RO_0000052[characteristic of/inheres in] some (RO_0000053[characterized by/bearer of] some (RO_0000059[concretizes] some 'identity document')))"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000015> "Jonathan M. Vajda"@en)
EquivalentClasses(<https://github.com/jonathanvajda/cco-d-acts/ont00000015> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000023> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000054> <https://github.com/jonathanvajda/cco-d-acts/ont00000007>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000197> <https://github.com/jonathanvajda/cco-d-acts/ont00000016>)))
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000015> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000016> (Identification Artifact)

AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "Identification Artifact"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#altLabel> <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "Identity Document"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "An Information Bearing Artifact that is the bearer of some Designative Information Content Entity and is the bearer of some Credential Role."@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "A bank statement"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#example> <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "A passport"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001754> <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "Modified significantly. Originally by Amanda Hicks (D-Acts; http://purl.obolibrary.org/obo/IAO_0020021) as 'identity document', which was a subclass of 'document', which is a Information Content Entity rather than an information bearing artifact. This is a critical difference. Moreover, the associated class having to do with 'documented identity' (another ICE) is obviated by CCO's Designative Information Content Entity. Original definition: \"A document that denotes some identity and is concretized by the bearer of some credential role.\" It was a defined class, equivalent to: IAO_0000310 and (IAO_0000136 some 'documented identity') and (RO_0000058 some (BFO_0000020 and (RO_0000052 some (RO_0000053 some 'credential role')))) and (RO_0000058 only (BFO_0000020 and (RO_0000052 some (RO_0000053 some 'credential role'))))"@en)
AnnotationAssertion(<https://www.commoncoreontologies.org/ont00001762> <https://github.com/jonathanvajda/cco-d-acts/ont00000016> "Jonathan M. Vajda"@en)
SubClassOf(<https://github.com/jonathanvajda/cco-d-acts/ont00000016> <https://www.commoncoreontologies.org/ont00000798>)

# Class: <https://github.com/jonathanvajda/cco-d-acts/ont00000018> (Social Act)

