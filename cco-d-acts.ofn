############################
#   Object Properties
############################

# Object Property: dacts:ont00000017 (legally revokes)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000017 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000017 "https://doi.org/10.1007/978-3-642-33618-8_57"^^xsd:anyURI)
AnnotationAssertion(rdfs:comment dacts:ont00000017 "Comment from original curator: It is important to note that this going out of existence of s is complete and unlike the going out of existence for material entities which basically always are transformed into something else. After the declaration nothing is left of the socio-legal generically dependent continuant in question."@en)
AnnotationAssertion(rdfs:label dacts:ont00000017 "legally revokes"@en)
AnnotationAssertion(skos:altLabel dacts:ont00000017 "socio-legally revokes"@en)
AnnotationAssertion(skos:definition dacts:ont00000017 "x socio-legally revokes y iff x is a deontic document act and y is a deontic role, such that y ceases to exist as a specified outcome of x."@en)
AnnotationAssertion(skos:example dacts:ont00000017 "A court order legally revokes a previously granted power of attorney role."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000017 "Use this property only where the document act itself brings the relevant socio-legal role out of existence, not where the act merely records an earlier revocation."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000017 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000017 "Jonathan M. Vajda"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000017 "Mathias Brochhausen"@en)
SubObjectPropertyOf(dacts:ont00000017 obo:BFO_0000057)
FunctionalObjectProperty(dacts:ont00000017)
AsymmetricObjectProperty(dacts:ont00000017)
IrreflexiveObjectProperty(dacts:ont00000017)
ObjectPropertyDomain(dacts:ont00000017 dacts:ont00000006)
ObjectPropertyRange(dacts:ont00000017 dacts:ont00000004)

# Object Property: dacts:ont00000022 (is normatively responsible for)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000022 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000022 "https://doi.org/10.1177/1463499606061731"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000022 "is normatively responsible for"@en)
AnnotationAssertion(skos:definition dacts:ont00000022 "x is normatively responsible for y, iff x is an Agent and y is an Entity, such that x bears some role with respect to y, that is realized in some act that regulates, oversees, or manages entities with respect to y, and x may be held normatively accountable for the outcomes of that regulation, oversight or management."@en)
AnnotationAssertion(skos:example dacts:ont00000022 "That organization is responsible for that service area"@en)
AnnotationAssertion(skos:example dacts:ont00000022 "This manager is responsible for the facility's condition and upkeep"@en)
AnnotationAssertion(skos:example dacts:ont00000022 "This person is parent is responsible for that Act of Vehicle Use"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000022 "Use this broader relation when the intended sense is supervisory or practical responsibility in general; use more specific accountability relations when causal or normative answerability is intended."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000022 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000022 "Jonathan M. Vajda"@en)
InverseObjectProperties(dacts:ont00000022 dacts:ont00000072)
ObjectPropertyDomain(dacts:ont00000022 cco2:ont00001017)
ObjectPropertyRange(dacts:ont00000022 obo:BFO_0000001)

# Object Property: dacts:ont00000023 (is causally responsible for)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000023 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000023 "https://doi.org/10.1177/1463499606061731"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000023 "is causally responsible for"@en)
AnnotationAssertion(skos:definition dacts:ont00000023 "x is causally responsible for y iff x is an agent and y is a process, x is an agent in the process z, such that z is the cause of y."@en)
AnnotationAssertion(skos:example dacts:ont00000023 "A driver is causally responsible for the collision process that followed the driver's negligent turn."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000023 "Use this relation for causal contribution to a process regardless of whether the contribution is blameworthy, lawful, or normatively excused."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000023 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000023 "Jonathan M. Vajda"@en)
ObjectPropertyDomain(dacts:ont00000023 cco2:ont00001017)
ObjectPropertyRange(dacts:ont00000023 obo:BFO_0000015)

# Object Property: dacts:ont00000024 (is normatively accountable for event)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000024 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000024 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000024 "is normatively accountable for event"@en)
AnnotationAssertion(skos:definition dacts:ont00000024 "x is normatively accountable for event y iff x is normatively responsible for y, and y is a process (or event)."@en)
AnnotationAssertion(skos:example dacts:ont00000024 "manager is responsible for the subordinate's actions"@en)
AnnotationAssertion(skos:example dacts:ont00000024 "parent is a responsible for a child"@en)
AnnotationAssertion(skos:example dacts:ont00000024 "parent is responsible or a child's actions"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000024 "Use this relation only where some norm makes the agent answerable for the event; mere causal involvement without answerability belongs under causal responsibility instead."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000024 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000024 "Jonathan M. Vajda"@en)
ObjectPropertyDomain(dacts:ont00000024 cco2:ont00001017)
ObjectPropertyRange(dacts:ont00000024 obo:BFO_0000015)

# Object Property: dacts:ont00000025 (has social group context)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000025 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000025 "https://doi.org/10.1177/1463499606061731"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000025 "has social group context"@en)
AnnotationAssertion(skos:definition dacts:ont00000025 "x has social group context y iff x is a role, y is a social group, and the bearer of x is a member of y."@en)
AnnotationAssertion(skos:example dacts:ont00000025 "A deontic role of parish member has social group context the parish community."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000025 "Use this relation for the group-level normative context of a role, not merely for the bearer's accidental membership in a crowd or aggregate."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000025 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000025 "Jonathan M. Vajda"@en)
InverseObjectProperties(dacts:ont00000025 dacts:ont00000026)
ObjectPropertyDomain(dacts:ont00000025 obo:BFO_0000023)
ObjectPropertyRange(dacts:ont00000025 cco2:ont00000914)

# Object Property: dacts:ont00000026 (is social group context of)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000026 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000026 "https://doi.org/10.1177/1463499606061731"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000026 "is social group context of"@en)
AnnotationAssertion(skos:definition dacts:ont00000026 "x is social group context of y iff y has social group context x."@en)
AnnotationAssertion(skos:example dacts:ont00000026 "A court is social group context of the judicial offices constituted within that court."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000026 "This is the inverse of 'has social group context' and should be used only for groups that ground the relevant role, not for groups merely affected by it."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000026 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000026 "Jonathan M. Vajda"@en)
ObjectPropertyDomain(dacts:ont00000026 cco2:ont00000914)
ObjectPropertyRange(dacts:ont00000026 obo:BFO_0000023)

# Object Property: dacts:ont00000068 (has specified input)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000068 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000068 "has specified input"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000068 obo:obi.owl)
AnnotationAssertion(skos:definition dacts:ont00000068 "x has specified input y iff x is a continuant, y is a planned act, a directive that prescribes y also specifies x, and x was present prior to the occurrence of x."@en)
AnnotationAssertion(skos:example dacts:ont00000068 "A notarization process has specified input the document whose signature is to be acknowledged."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000068 "Use this relation only where the continuant is specified in the relevant plan as an input and is not merely an incidental participant."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000068 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000068 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000068 "PERSON: Bjoern Peters"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000068 "PERSON: Jonathan Vajda"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000068 "PERSON: Larry Hunter"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000068 "PERSON: Melanie Coutot"@en)
SubObjectPropertyOf(dacts:ont00000068 cco2:ont00001921)
InverseObjectProperties(dacts:ont00000068 dacts:ont00000069)
ObjectPropertyDomain(dacts:ont00000068 cco2:ont00000228)
ObjectPropertyRange(dacts:ont00000068 obo:BFO_0000002)

# Object Property: dacts:ont00000069 (is specified input of)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000069 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000069 "is specified input of"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000069 obo:obi.owl)
AnnotationAssertion(skos:definition dacts:ont00000069 "An object property that relates a continuant to a planned act for which the continuant is specified as an input."@en)
AnnotationAssertion(skos:example dacts:ont00000069 "A blank marriage license form is specified input of the document act in which it is completed and signed."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000069 "Use this inverse relation only when the continuant is explicitly specified as an input to the planned act rather than merely present during it."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000069 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000069 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000069 "PERSON: Bjoern Peters"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000069 "PERSON: Jonathan Vajda"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000069 "PERSON: Larry Hunter"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000069 "PERSON: Melanie Coutot"@en)
SubObjectPropertyOf(dacts:ont00000069 cco2:ont00001841)
ObjectPropertyDomain(dacts:ont00000069 obo:BFO_0000002)
ObjectPropertyRange(dacts:ont00000069 cco2:ont00000228)

# Object Property: dacts:ont00000070 (has specified output)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000070 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000070 "has specified output"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000070 obo:obi.owl)
AnnotationAssertion(skos:definition dacts:ont00000070 "An object property that relates a planned act to a continuant that the plan prescribing that act specifies as an output."@en)
AnnotationAssertion(skos:example dacts:ont00000070 "A lawyer licensing process has specified output the license document issued upon successful admission."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000070 "Use this relation only where the continuant is prescribed as an output of the planned act, not merely observed or reused at its conclusion."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000070 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000070 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000070 "PERSON: Bjoern Peters"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000070 "PERSON: Jonathan Vajda"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000070 "PERSON: Larry Hunter"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000070 "PERSON: Melanie Coutot"@en)
SubObjectPropertyOf(dacts:ont00000070 cco2:ont00001986)
InverseObjectProperties(dacts:ont00000070 dacts:ont00000071)
ObjectPropertyDomain(dacts:ont00000070 cco2:ont00000228)
ObjectPropertyRange(dacts:ont00000070 obo:BFO_0000002)

# Object Property: dacts:ont00000071 (is specified output of)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000071 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000071 "is specified output of"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000071 obo:obi.owl)
AnnotationAssertion(skos:definition dacts:ont00000071 "An object property that relates a continuant to a planned act for which the continuant is specified as an output."@en)
AnnotationAssertion(skos:example dacts:ont00000071 "A completed court order is specified output of the judicial signing process that issues it."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000071 "Use this inverse relation only when the continuant is explicitly specified to be present as an output at the conclusion of the planned act."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000071 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000071 "PERSON: Alan Ruttenberg"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000071 "PERSON: Bjoern Peters"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000071 "PERSON: Jonathan Vajda"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000071 "PERSON: Larry Hunter"@en)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000071 "PERSON: Melanie Coutot"@en)
SubObjectPropertyOf(dacts:ont00000071 cco2:ont00001816)
ObjectPropertyDomain(dacts:ont00000071 obo:BFO_0000002)
ObjectPropertyRange(dacts:ont00000071 cco2:ont00000228)

# Object Property: dacts:ont00000072 (has normatively responsible agent)

AnnotationAssertion(rdfs:label dacts:ont00000072 "has normatively responsible agent"@en)
AnnotationAssertion(skos:definition dacts:ont00000072 "x has normatively responsible agent y iff y is normatively responsible for x."@en)
AnnotationAssertion(skos:example dacts:ont00000072 "This parent is normatively responsible for the care of the child."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000072 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000072 "Jonathan M. Vajda"@en)

# Object Property: dacts:ont00000073 (has legal custody of)

AnnotationAssertion(rdfs:label dacts:ont00000073 "has legal custody of"@en)
AnnotationAssertion(skos:definition dacts:ont00000073 " x has legal custody of y iff x is an Agent, y is a material entity, such that x is legally responsible for the care or well-being of y, and there is some site z for which x is recognized as having control for fulfilling that responsibility toward y and y is located in z."@en)
AnnotationAssertion(skos:example dacts:ont00000073 "This parent has legal custody of the child."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000073 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000073 "Jonathan M. Vajda"@en)
SubObjectPropertyOf(dacts:ont00000073 dacts:ont00000022)
InverseObjectProperties(dacts:ont00000073 dacts:ont00000074)

# Object Property: dacts:ont00000074 (is legally in the custody of)

AnnotationAssertion(rdfs:label dacts:ont00000074 "is legally in the custody of"@en)
AnnotationAssertion(skos:definition dacts:ont00000074 " x is legally in the custody of y iff y has legal custody of x."@en)
AnnotationAssertion(skos:example dacts:ont00000074 "The child is legally in the custody of the parent."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000074 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000074 "Jonathan M. Vajda"@en)
SubObjectPropertyOf(dacts:ont00000074 dacts:ont00000072)



############################
#   Classes
############################

# Class: dacts:ont00000001 (Document Act Input Document)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000001 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000001 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:comment dacts:ont00000001 "Originally a subclass of document (a subclass of Information Content Entity). Since it takes an input, Information Bearing Artifact is a better genus."@en)
AnnotationAssertion(rdfs:label dacts:ont00000001 "Document Act Input Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000001 "A Document that is intended to be the specified input in a Deontic Document Act. It has a Plan Specification as a part that specifies the intended socio-legal entities that are created through the document (objective specification) and the way in which the Deontic Document Act is to be performed (by signing, by stamping, etc.) (action specification)."@en)
AnnotationAssertion(skos:example dacts:ont00000001 "A loan application form that is not yet filled with personal and financial information."@en)
AnnotationAssertion(skos:example dacts:ont00000001 "A marriage license that is intended to be used in the documented solemnization of marital vows."@en)
AnnotationAssertion(skos:example dacts:ont00000001 "An informed consent form that is intended to have a subject's PII data fields filled in."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000001 "Use this class for documents prepared to serve as specified inputs to document acts; a completed output document produced by the act is not itself an input document merely because it persists afterward."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000001 "Modified, originally from Mathias Brochhausen (D-Acts Ontology), http://purl.obolibrary.org/obo/IAO_0021007"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000001 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000001 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000001 cco2:ont00001298)

# Class: dacts:ont00000003 (Standing Declaration)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000003 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000003 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000003 "Standing Declaration"@en)
AnnotationAssertion(skos:altLabel dacts:ont00000003 "enactment"@en)
AnnotationAssertion(skos:definition dacts:ont00000003 "A social act that postulates a socio-legal fact for a specified group of people or organizations."@en)
AnnotationAssertion(skos:example dacts:ont00000003 "A verbal utterance to obligate oneself to take care of a neighbor's pet animal."@en)
AnnotationAssertion(skos:example dacts:ont00000003 "A written document to permit some person to reside in exchange for a fee."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000003 "Use this class for declarations that institute or maintain a standing social or legal condition for some audience or group, not for momentary expressions lacking enduring institutional significance."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000003 "Modified, originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021102"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000003 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000003 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000003 cco2:ont00001327)

# Class: dacts:ont00000004 (Deontic Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000004 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000004 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:comment dacts:ont00000004 "This definition attempts to capture \"A role that inheres in an agent and which is externally grounded in the normative expectations that other agents within a social context have concerning how that agent should behave.\" (D-Acts, IAO_0021008) In an effort to be more CCO-conformant, I have followed similar recommendations as Eric Merrell et al. (2021), omitting their condition that the agent must be a member of that group of agents."@en)
AnnotationAssertion(rdfs:label dacts:ont00000004 "Deontic Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000004 "A Role that inheres in an Agent and which is externally grounded in the normative expectations of some Group of Agents concerning how that Agent should behave."@en)
AnnotationAssertion(skos:example dacts:ont00000004 "Legal judge role"@en)
AnnotationAssertion(skos:example dacts:ont00000004 "Mandatory reporter role"@en)
AnnotationAssertion(skos:example dacts:ont00000004 "President role"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000004 "Use this class only for roles whose content is grounded in norms, institutions, or other deontic structures; not every socially expected pattern of behavior constitutes a deontic role."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000004 "Modified; originally from Mathias Brochhausen & Neil Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021008 ('deontic role')"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000004 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000004 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000004 obo:BFO_0000023)

# Class: dacts:ont00000005 (Deontic Declaration)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000005 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000005 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000005 "Deontic Declaration"@en)
AnnotationAssertion(skos:definition dacts:ont00000005 "A Social Act that creates, revokes, or modifies a Deontic Role."@en)
AnnotationAssertion(skos:example dacts:ont00000005 "Oath to speak the truth on the witness stand in a court of law"@en)
AnnotationAssertion(skos:example dacts:ont00000005 "Permission for a surgeon to perform a hysterectomy"@en)
AnnotationAssertion(skos:example dacts:ont00000005 "Pronouncement of knighthood"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000005 "Use this class for social acts that create, modify, or revoke deontic roles; acts that merely describe or discuss such roles without altering them do not belong here."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000005 "Modified, originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021009 . Equivalent to some Social Act that either 'legally revokes' some 'deontic role' OR 'has_specified_output' some 'deontic role'"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000005 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000005 "Jonathan M. Vajda"@en)
EquivalentClasses(dacts:ont00000005 ObjectIntersectionOf(cco2:ont00001327 ObjectUnionOf(ObjectSomeValuesFrom(dacts:ont00000017 dacts:ont00000004) ObjectSomeValuesFrom(dacts:ont00000070 dacts:ont00000004))))
SubClassOf(dacts:ont00000005 cco2:ont00001327)

# Class: dacts:ont00000006 (Deontic Document Act)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000006 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000006 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000006 "Deontic Document Act"@en)
AnnotationAssertion(skos:definition dacts:ont00000006 "A Deontic Declaration that creates, revokes, or modifies a Deontic Role by legitimately manipulating (signing, stamping, publishing) a Document"@en)
AnnotationAssertion(skos:example dacts:ont00000006 "Attestation of degree conferral by means of a diploma"@en)
AnnotationAssertion(skos:example dacts:ont00000006 "Issuance of a citation that an individual has violated a legal regulation"@en)
AnnotationAssertion(skos:example dacts:ont00000006 "my filling in an immigration form, a judge's signing and stamping a court order (Mathias Brochhausen)"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000006 "Use this class only where a document is constitutively involved in the creation, modification, or revocation of the deontic role, not where a document is merely consulted or mentioned."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000006 "Modified, originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021001 .Their class is a defined class, equivalent to some Deontic Declaration that 'has_specified_input' some 'document act input document' AND 'has_specified_output' some 'document'"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000006 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000006 "Jonathan M. Vajda"@en)
EquivalentClasses(dacts:ont00000006 ObjectIntersectionOf(dacts:ont00000005 ObjectSomeValuesFrom(dacts:ont00000068 dacts:ont00000001) ObjectSomeValuesFrom(dacts:ont00000070 cco2:ont00001298)))
SubClassOf(dacts:ont00000006 dacts:ont00000005)

# Class: dacts:ont00000007 (Act of Authentication)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000007 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000007 "Act of Authentication"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000007 obo:IAO_0020023)
AnnotationAssertion(skos:altLabel dacts:ont00000007 "Authentication"@en)
AnnotationAssertion(skos:definition dacts:ont00000007 "An Intentional Act that verifies the legitimacy and truth value of some identity claim, whether that claim was given explicitly or implicitly"@en)
AnnotationAssertion(skos:example dacts:ont00000007 "I order a beer and the bartender authenticates my age by looking at my DOB on my driver's license. I sign into my email account, and the system authenticates my permission to read the email by checking the password I enter against my password listed in the database. (Amanda Hicks)"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000007 "Use this class for intentional acts that verify an identity-relevant claim; broader checking or validation processes that do not concern identity or credentials should be modeled separately."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000007 "Modified, originally from Amanda Hicks (D-Acts), http://purl.obolibrary.org/obo/IAO_0020023. Originally came with axioms: BFO_0000015 and (realizes some 'credential role') and (BFO_0000057 some IAO_0000027) and (BFO_0000057 some ( inverse (IAO_0000136) some IAO_0000027))"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000007 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000007 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000007 cco2:ont00000228)

# Class: dacts:ont00000008 (Claimant Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000008 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000008 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:comment dacts:ont00000008 "Comment from source: Claimant roles can either be discharged by one act of fulfilling a duty (e.g. when I pay back $5 owed to a friend) or they can remain intact and require ongoing adhering to a duty. https://plato.stanford.edu/entries/rights/#FormRighHohfAnalSyst discuss the claim of a child to freedom from abuse. That claim remains in existence and the duty to not abuse the child needs to be continuously be acted upon, by a multitude of agents (which all have a duty holder role). This claim is mutually dependent on the duty to abstain from abusing the child."@en)
AnnotationAssertion(rdfs:label dacts:ont00000008 "Claimant Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000008 "A Deontic Role that inheres in an Agent A, that mutually depends on the existence of a Duty Holder Role borne by Agent B, and that specifies B performaing or abstaining from some Act C, or providing or surrendering some Continuant D to A."@en)
AnnotationAssertion(skos:example dacts:ont00000008 "A child bears a claimant role against a guardian for the provision of legally required care."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000008 "Use this class for the claim-right side of a correlative claim-duty pair; it is not coextensive with every desire, request, or expectation someone may have."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000008 "Modified, originally from Brochhausen and Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021013 which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000008 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000008 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000008 dacts:ont00000004)

# Class: dacts:ont00000009 (Duty Holder Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000009 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000009 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:comment dacts:ont00000009 "Comment from source: Claimant roles can either be discharged by one act of fulfilling a duty (e.g. when I pay back $5 owed to a friend) or they can remain intact and require ongoing adhering to a duty. https://plato.stanford.edu/entries/rights/#FormRighHohfAnalSyst discuss the claim of a child to freedom from abuse. That claim remains in existence and the duty to not abuse the child needs to be continuously be acted upon, by a multitude of agents (which all have a duty holder role). This claim is mutually dependent on the duty to abstain from abusing the child."@en)
AnnotationAssertion(rdfs:label dacts:ont00000009 "Duty Holder Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000009 "A Deontic Role that inheres in an Agent A, that mutually depends on the existence of a Claimant Role borne by Agent B, and that specifies A performing or abstaining from some Act C, or providing or surrendering some Continuant D to B."@en)
AnnotationAssertion(skos:example dacts:ont00000009 "A guardian bears a duty holder role to refrain from neglecting a child in the guardian's care."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000009 "Use this class for the duty-bearing side of a correlative claim-duty pair; not every burden or practical expectation counts as a duty holder role."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000009 "Modified, originally from Brochhausen and Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021016 ('duty holder role') which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000009 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000009 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000009 dacts:ont00000004)

# Class: dacts:ont00000010 (Deontic Power Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000010 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000010 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000010 "Deontic Power Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000010 "A Deontic Role that, if realized, is realized by its bearer's creating, revoking, or modifying some Deontic Role."@en)
AnnotationAssertion(skos:example dacts:ont00000010 "Employer role has continuant part some deontic power role"@en)
AnnotationAssertion(skos:example dacts:ont00000010 "Governor role has continuant part some deontic power role"@en)
AnnotationAssertion(skos:example dacts:ont00000010 "Legal judge role has continuant part some deontic power role"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000010 "Use this class only for roles whose realization changes deontic incidents, such as permissions, claims, or duties; ordinary abilities without normative force do not belong here."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000010 "Modified, originally from Mathias Brochhausen & J. Neil Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021023 ('power role')"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000010 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000010 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000010 dacts:ont00000004)

# Class: dacts:ont00000011 (Privilege Holder Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000011 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000011 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000011 "Privilege Holder Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000011 "A Deontic Role that inheres in an Agent A, that specifies that no Agent B bears a Claimant Role against A performing Act C."@en)
AnnotationAssertion(skos:example dacts:ont00000011 "A property owner's role of being at liberty to enter the owner's own land absent a countervailing claim."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000011 "Use this class for Hohfeldian liberties or privileges; the fact that a bearer can physically perform an act does not by itself imply a privilege holder role."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000011 "Modified; originally from Mathias Brochhausen and J. Neil Otte (D-Acts), http://purl.obolibrary.org/obo/IAO_0021019 which in turn was derived from Hohfeld, WN: Fundamental Legal Conceptions as Applied in Judicial Reasoning. Yale University Press, 1919."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000011 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000011 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000011 dacts:ont00000004)

# Class: dacts:ont00000012 (Document Act Performer Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000012 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000012 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000012 "Document Act Performer Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000012 "A Role inhering in an Agent (either a human, an organization, or an aggregate of either) that is realized by the bearer being an agent (initiating participant) in a Document Act."@en)
AnnotationAssertion(skos:example dacts:ont00000012 "a judge's role of signing a court order"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000012 "Use this class for the participant role of an agent in a document act, not for every occupational role from which document acts happen to be performed."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000012 "Modified; originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021031"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000012 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000012 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000012 obo:BFO_0000023)

# Class: dacts:ont00000013 (Document Act Template Creator Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000013 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000013 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000013 "Document Act Template Creator Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000013 "A Role that inheres in an Agent (a human, organization, or aggregate of these) that is realized in preparing a Document that is the specified input to a Document Act and is the Input Document of a Document Act."@en)
AnnotationAssertion(skos:example dacts:ont00000013 "The role of the U.S. Citizenship and Immigration Service realized by the creation of an immigration form that is being filled in, the role of a national professional association realized by the creation of a clinical guideline that is to be certified"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000013 "Use this class for the role realized in preparing reusable or intended input documents for later document acts, not for every act of ordinary authorship."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000013 "Modified; originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021021"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000013 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000013 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000013 obo:BFO_0000023)

# Class: dacts:ont00000014 (Deontic Declaration Performer Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000014 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000014 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000014 "Deontic Declaration Performer Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000014 "A Role inhering in an Agent or Aggregate of Agents that is realized by the bearer being the active participant (agent in) a Deontic Declaration."@en)
AnnotationAssertion(skos:example dacts:ont00000014 "A minister's role in performing the declaration that pronounces two applicants married."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000014 "Use this class for the bearer of the active participant role in a deontic declaration, not for passive witnesses or downstream recordkeepers."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000014 "Modified; originally from Mathias Brochhausen (D-Acts), http://purl.obolibrary.org/obo/IAO_0021022 . Originally a subclass of BFO_0000023 ('role'), but this is clearly a subclass of deontic role."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000014 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000014 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000014 dacts:ont00000004)

# Class: dacts:ont00000015 (Credential Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000015 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000015 "Credential Role"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000015 obo:IAO_0020024)
AnnotationAssertion(skos:definition dacts:ont00000015 "A Role that inheres in an Identification Artifact and is realized by some Act of Authentication process."@en)
AnnotationAssertion(skos:example dacts:ont00000015 "A passport's role for an act of authentication for boarding an international flight"@en)
AnnotationAssertion(skos:example dacts:ont00000015 "A server's role in an authentication into an online banking system"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000015 "Use this class for roles borne by artifacts or systems that function as credentials in authentication, not for the human status or identity being attested."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000015 "Modified; originally by Amanda Hicks (D-Acts), http://purl.obolibrary.org/obo/IAO_0020024. See the notes on 'Identification Artifact', which clarifies why 'Identity Document' is significantly corrected and why 'documented identity' is obviated. Original definition 'A role that inheres in a concretization of an identity document and is realized by an authentication process.' Equivalent class is adjusted, since 'identity document' is not an ICE but rather artifact IBE. Originally: to BFO_0000023[role] and (RO_0000054[realized in] some authentication) and (RO_0000052[characteristic of/inheres in] some (RO_0000053[characterized by/bearer of] some (RO_0000059[concretizes] some 'identity document')))"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000015 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000015 "Jonathan M. Vajda"@en)
EquivalentClasses(dacts:ont00000015 ObjectIntersectionOf(obo:BFO_0000023 ObjectSomeValuesFrom(obo:BFO_0000054 dacts:ont00000007) ObjectSomeValuesFrom(obo:BFO_0000197 dacts:ont00000016)))
SubClassOf(dacts:ont00000015 obo:BFO_0000023)

# Class: dacts:ont00000016 (Identification Artifact)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000016 obo:IAO_0000123)
AnnotationAssertion(rdfs:label dacts:ont00000016 "Identification Artifact"@en)
AnnotationAssertion(rdfs:seeAlso dacts:ont00000016 obo:IAO_0020021)
AnnotationAssertion(skos:altLabel dacts:ont00000016 "Identity Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000016 "An Information Bearing Artifact that is the bearer of some Designative Information Content Entity and is the bearer of some Credential Role."@en)
AnnotationAssertion(skos:example dacts:ont00000016 "A bank statement"@en)
AnnotationAssertion(skos:example dacts:ont00000016 "A passport"@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000016 "Use this class for information-bearing artifacts that support authentication by bearing credential-relevant content; the class is intentionally artifact-centered rather than content-centered."@en)
AnnotationAssertion(cco2:ont00001754 dacts:ont00000016 "Modified significantly. Originally by Amanda Hicks (D-Acts; http://purl.obolibrary.org/obo/IAO_0020021) as 'identity document', which was a subclass of 'document', which is a Information Content Entity rather than an information bearing artifact. This is a critical difference. Moreover, the associated class having to do with 'documented identity' (another ICE) is obviated by CCO's Designative Information Content Entity. Original definition: \"A document that denotes some identity and is concretized by the bearer of some credential role.\" It was a defined class, equivalent to: IAO_0000310 and (IAO_0000136 some 'documented identity') and (RO_0000058 some (BFO_0000020 and (RO_0000052 some (RO_0000053 some 'credential role')))) and (RO_0000058 only (BFO_0000020 and (RO_0000052 some (RO_0000053 some 'credential role'))))"@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000016 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000016 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000016 cco2:ont00000798)

# Class: dacts:ont00000018 (Social Act)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000018 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000018 "https://plato.stanford.edu/archives/spr2024/entries/social-ontology/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000018 "Social Act"@en)
AnnotationAssertion(skos:definition dacts:ont00000018 "A planned act that creates, modifies, or extinguishes a social entity by means of communication between one or more agents."@en)
AnnotationAssertion(skos:example dacts:ont00000018 "A legislature enacts a statute by communicating it in an institutionally recognized setting."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000018 "Use this class for communicative acts that create, modify, or extinguish social entities; communication lacking such constitutive effect does not qualify."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000018 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000018 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000018 cco2:ont00000228)

# Class: dacts:ont00000019 (Deontic Act)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000019 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000019 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000019 "Deontic Act"@en)
AnnotationAssertion(skos:definition dacts:ont00000019 "A social act that creates, modifies, or extinguishes a deontic role."@en)
AnnotationAssertion(skos:example dacts:ont00000019 "A board resolution creates a treasurer's duty to make quarterly reports."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000019 "Use this class for social acts whose primary social output is the creation, modification, or extinguishing of deontic roles."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000019 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000019 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000019 dacts:ont00000018)

# Class: dacts:ont00000020 (Speech Act)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000020 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000020 "https://plato.stanford.edu/archives/fall2023/entries/speech-acts/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000020 "Speech Act"@en)
AnnotationAssertion(skos:definition dacts:ont00000020 "A social act that changes some social arrangement by means of speech."@en)
AnnotationAssertion(skos:example dacts:ont00000020 "A judge orally sentences a defendant in open court."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000020 "Use this class where spoken or otherwise uttered linguistic performance is the constitutive medium of the social act; written or signed performances belong under document-act classes instead."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000020 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000020 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000020 dacts:ont00000018)

# Class: dacts:ont00000021 (Document Act)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000021 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000021 "https://doi.org/10.1515/9783110322507.120"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000021 "Document Act"@en)
AnnotationAssertion(skos:definition dacts:ont00000021 "A social act that changes some social arrangement by means of document."@en)
AnnotationAssertion(skos:example dacts:ont00000021 "A signed deed transfers title to a parcel of land."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000021 "Use this class where a document is the constitutive medium through which the social arrangement is changed, not where a document merely records or reports a change brought about otherwise."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000021 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000021 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000021 dacts:ont00000018)

# Class: dacts:ont00000027 (Normative Accountability Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000027 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000027 "Taxonomy of disposition parthood https://hal.science/hal-02983145/"@en)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000027 "https://ceur-ws.org/Vol-2285/ICBO_2018_paper_13.pdf"@en)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000027 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000027 "Normative Accountability Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000027 "A Deontic Role that inheres in an Agent and is realized in that agent's being answerable within some social or legal context for whether a relevant act or outcome conforms to applicable norms."@en)
AnnotationAssertion(skos:example dacts:ont00000027 "A supervisor's role of answering to an accrediting body for a laboratory's compliance failures."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000027 "Use this class where answerability depends on a norm or institution, even when the bearer did not directly cause every relevant event."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000027 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000027 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000027 dacts:ont00000004)

# Class: dacts:ont00000028 (Causal Accountability Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000028 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000028 "https://doi.org/10.1177/1463499606061731"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000028 "Causal Accountability Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000028 "A Role that inheres in an Agent and is realized in that agent's being answerable for an outcome by virtue of the agent's causal contribution to a process producing it."@en)
AnnotationAssertion(skos:example dacts:ont00000028 "A ship captain's role of being held answerable for a collision caused by the navigation process under the captain's control."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000028 "Use this class only where causal contribution is central to the accountability relation; normative accountability without causal contribution belongs under Normative Accountability Role instead."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000028 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000028 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000028 obo:BFO_0000023)

# Class: dacts:ont00000029 (Obligor Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000029 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000029 "https://www.law.cornell.edu/wex/obligor"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000029 "Obligor Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000029 "A Deontic Role that inheres in an Agent and is externally grounded in an obligation owed to some obligee, such that the bearer is required to perform, refrain from, or transfer something."@en)
AnnotationAssertion(skos:example dacts:ont00000029 "A tenant's role of owing rent payments to a landlord under a lease."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000029 "Use this class for the duty-bearing side of an obligation relation; a bearer can be an obligor even when performance is not yet due."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000029 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000029 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000029 dacts:ont00000004)

# Class: dacts:ont00000030 (Obligee Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000030 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000030 "https://www.law.cornell.edu/wex/obligee"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000030 "Obligee Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000030 "A Deontic Role that inheres in an Agent and is externally grounded in an obligation owed by some obligor, such that the bearer is entitled to the obligor's performance, forbearance, or transfer."@en)
AnnotationAssertion(skos:example dacts:ont00000030 "A lender's role of being entitled to repayment by a borrower."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000030 "Use this class for the right-holding side of an obligation relation; it is correlative to an obligor role."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000030 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000030 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000030 dacts:ont00000004)

# Class: dacts:ont00000031 (Act of Marriage Pronouncing)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000031 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000031 "https://www.law.cornell.edu/wex/solemnization_of_marriage"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000031 "Act of Marriage Pronouncing"@en)
AnnotationAssertion(skos:definition dacts:ont00000031 "A Deontic Act that creates a marital status by an authorized officiant's declaring that the parties are married."@en)
AnnotationAssertion(skos:example dacts:ont00000031 "A judge pronounces two applicants married during a civil ceremony."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000031 "Use this class for the performative pronouncement itself, not for the larger wedding ceremony or the administrative issuance of a marriage license."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000031 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000031 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000031 dacts:ont00000019)

# Class: dacts:ont00000032 (Act of Authorizing)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000032 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000032 "https://www.law.cornell.edu/wex/authorize"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000032 "Act of Authorizing"@en)
AnnotationAssertion(skos:definition dacts:ont00000032 "A Deontic Declaration that grants an agent or organization the authority, permission, or institutional standing to perform some specified act."@en)
AnnotationAssertion(skos:example dacts:ont00000032 "A hospital administrator issues an authorization allowing a clinician to access a restricted record set."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000032 "Use this class where the declaration itself confers authority or permission, not where it merely reports an authorization granted elsewhere."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000032 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000032 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000032 dacts:ont00000005)

# Class: dacts:ont00000033 (Release Form Document)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000033 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000033 "https://www.law.cornell.edu/wex/release"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000033 "Release Form Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000033 "A Document Act Input Document that is prepared to be executed in a document act whose output is the waiver, discharge, or surrender of a claim, duty, or liability."@en)
AnnotationAssertion(skos:example dacts:ont00000033 "A liability waiver signed before participation in a hazardous recreational activity."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000033 "Use this class for the input document prepared for execution; a completed and legally effective release may additionally bear output-document roles not modeled here."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000033 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000033 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000033 dacts:ont00000001)

# Class: dacts:ont00000034 (Act of Permitting)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000034 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000034 "https://plato.stanford.edu/entries/rights/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000034 "Act of Permitting"@en)
AnnotationAssertion(skos:definition dacts:ont00000034 "A Deontic Declaration that creates or confirms a Privilege Holder Role with respect to some specified act or omission."@en)
AnnotationAssertion(skos:example dacts:ont00000034 "A city issues a permit allowing a contractor to close a lane for utility work."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000034 "Use this class where the declaration grants a liberty or permission; if the same act also imposes obligations, model those outputs separately."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000034 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000034 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000034 dacts:ont00000005)

# Class: dacts:ont00000035 (Act of Obligating)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000035 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000035 "https://www.law.cornell.edu/wex/obligation"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000035 "Act of Obligating"@en)
AnnotationAssertion(skos:definition dacts:ont00000035 "A Deontic Declaration that creates or confirms an Obligor Role with respect to some specified performance, forbearance, or transfer."@en)
AnnotationAssertion(skos:example dacts:ont00000035 "A signed employment contract obligates the employer to pay wages and the employee to perform agreed work."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000035 "Use this class where the declaration itself creates or confirms an obligation, not where it merely describes a pre-existing duty."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000035 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000035 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000035 dacts:ont00000005)

# Class: dacts:ont00000036 (Act of Prohibiting)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000036 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000036 "https://www.law.cornell.edu/wex/legal_duty"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000036 "Act of Prohibiting"@en)
AnnotationAssertion(skos:definition dacts:ont00000036 "A Deontic Declaration that creates or confirms a Duty Holder Role to refrain from some specified act."@en)
AnnotationAssertion(skos:example dacts:ont00000036 "A court injunction prohibits a company from disclosing specified trade-secret information."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000036 "Use this class for declarations that normatively forbid conduct; a mere warning that conduct is risky or inadvisable does not suffice."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000036 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000036 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000036 dacts:ont00000005)

# Class: dacts:ont00000037 (Act of Notarizing)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000037 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000037 "https://www.law.cornell.edu/wex/notarize"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000037 "Act of Notarizing"@en)
AnnotationAssertion(skos:definition dacts:ont00000037 "A Deontic Document Act that authenticates a signature, acknowledgment, oath, or copy on a document by means of a notary's official attestation."@en)
AnnotationAssertion(skos:example dacts:ont00000037 "A notary public witnesses a principal's signature on a power-of-attorney document and affixes a seal."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000037 "Use this class for the notarial act itself, not for the broader transaction in which the notarized document is later used."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000037 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000037 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000037 dacts:ont00000006)

# Class: dacts:ont00000038 (Mortgage Contract Document)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000038 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000038 "https://www.law.cornell.edu/wex/mortgage"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000038 "Mortgage Contract Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000038 "A Document Act Input Document that is prepared to be executed in a transaction creating a mortgage interest as security for a debt or other obligation."@en)
AnnotationAssertion(skos:example dacts:ont00000038 "A residential mortgage instrument signed at a real-estate closing."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000038 "Use this class for the document prepared for execution in the mortgage transaction; separate classes would be needed for recorded copies, notes, or deeds of trust if finer distinctions are required."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000038 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000038 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000038 dacts:ont00000001)

# Class: dacts:ont00000039 (Mortgage Contract Information Content)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000039 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000039 "https://www.law.cornell.edu/wex/mortgage"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000039 "Mortgage Contract Information Content"@en)
AnnotationAssertion(skos:definition dacts:ont00000039 "A Directive Information Content Entity that specifies the terms under which a mortgage interest secures repayment of a debt or other obligation."@en)
AnnotationAssertion(skos:example dacts:ont00000039 "The clauses in a signed mortgage instrument specifying the secured property, repayment terms, and default consequences."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000039 "Use this class for the content borne by a mortgage document, not for the document artifact itself."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000039 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000039 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000039 cco2:ont00000965)

# Class: dacts:ont00000040 (Owner Entity Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000040 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000040 "https://plato.stanford.edu/entries/property/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000040 "Owner Entity Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000040 "A Role that inheres iin a person and that, when it is realized, is realized in a social act and whose bearer exercises control over a possession, where this control is permitted by one or more deontic roles, which are parts of the owner role."@en)
AnnotationAssertion(skos:example dacts:ont00000040 "A homeowner's role of controlling access to a house and transferring title to it."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000040 "Use this class for the role inhering in the owner, not for the owned thing itself or for every factual possessor lacking socially recognized title or authority."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000040 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000040 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000040 obo:BFO_0000023)

# Class: dacts:ont00000041 (Owned Entity Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000041 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000041 "https://plato.stanford.edu/entries/property/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000041 "Owned Entity Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000041 "A Role that inheres in an Entity and is externally grounded in a social or legal arrangement such that the entity stands as the object over which some bearer has an Owner Entity Role."@en)
AnnotationAssertion(skos:example dacts:ont00000041 "The role of a parcel of land that is the object of a homeowner's ownership."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000041 "Use this class for the role of the owned entity within an ownership arrangement, not for ordinary material constitution or physical containment relations."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000041 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000041 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000041 obo:BFO_0000023)

# Class: dacts:ont00000042 (Act of Ownership)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000042 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000042 "https://plato.stanford.edu/entries/property/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000042 "Act of Ownership"@en)
AnnotationAssertion(skos:definition dacts:ont00000042 "A Deontic Act that creates, transfers, acknowledges, or extinguishes an Owner Entity Role with respect to some entity."@en)
AnnotationAssertion(skos:example dacts:ont00000042 "The signing and delivery of a deed that transfers ownership of a parcel of land."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000042 "Use this class for social acts that change ownership status, not for mere physical taking possession without recognized normative effect."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000042 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000042 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000042 dacts:ont00000019)

# Class: dacts:ont00000043 (Act of Advance Directive Declaring)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000043 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000043 "https://www.law.cornell.edu/wex/advance_directive"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000043 "Act of Advance Directive Declaring"@en)
AnnotationAssertion(skos:definition dacts:ont00000043 "A Deontic Act that creates an advance directive by documenting instructions or proxy designations for future healthcare decision-making under specified incapacity conditions."@en)
AnnotationAssertion(skos:example dacts:ont00000043 "A patient signs and witnesses a living will naming a healthcare surrogate."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000043 "Use this class for the constitutive document act that creates the directive, not for later clinical reliance on the directive during treatment."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000043 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000043 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000043 dacts:ont00000019)

# Class: dacts:ont00000044 (Advance Directive)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000044 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000044 "https://www.law.cornell.edu/wex/advance_directive"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000044 "Advance Directive"@en)
AnnotationAssertion(skos:definition dacts:ont00000044 "A Document Act Input Document that bears information intended to govern future healthcare decisions if its author later lacks decisional capacity."@en)
AnnotationAssertion(skos:example dacts:ont00000044 "A signed living will stored in a patient's medical records."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000044 "Use this class for the document prepared and executed to state future healthcare instructions or designate a proxy; a broader care plan is not necessarily an advance directive."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000044 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000044 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000044 dacts:ont00000001)

# Class: dacts:ont00000045 (Act of Estate Planning)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000045 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000045 "https://www.law.cornell.edu/wex/will"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000045 "Act of Estate Planning"@en)
AnnotationAssertion(skos:definition dacts:ont00000045 "A Deontic Act that creates, revises, or arranges the future management or distribution of a person's estate."@en)
AnnotationAssertion(skos:example dacts:ont00000045 "A consultation and drafting session in which a client prepares a will, trust, and powers of attorney."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000045 "Use this class for the broader planned activity of arranging estate-related directives and transfers; particular constitutive declarations within it may instantiate more specific document-act classes."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000045 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000045 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000045 dacts:ont00000019)

# Class: dacts:ont00000046 (Heir Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000046 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000046 "https://www.law.cornell.edu/wex/heir"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000046 "Heir Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000046 "A Deontic Role that inheres in an Agent and entitles its bearer to receive some portion of a decedent's estate under an inheritance arrangement."@en)
AnnotationAssertion(skos:example dacts:ont00000046 "A child designated to receive a share of a deceased parent's estate."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000046 "This class is used broadly enough to cover heirs and heir-like designated recipients in estate arrangements; if strict distinction between heirs at law and beneficiaries is needed, add separate subclasses."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000046 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000046 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000046 dacts:ont00000004)

# Class: dacts:ont00000047 (Act of Asset Inheriting)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000047 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000047 "https://www.law.cornell.edu/wex/inherit"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000047 "Act of Asset Inheriting"@en)
AnnotationAssertion(skos:definition dacts:ont00000047 "A Deontic Act through which an heir or similar successor acquires an Owner Entity Role in an asset of a decedent's estate."@en)
AnnotationAssertion(skos:example dacts:ont00000047 "A beneficiary accepts distribution of a house from an estate and thereby acquires ownership."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000047 "Use this class for the ownership-changing social act in succession, not for the biological inheritance of traits or for the whole probate proceeding."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000047 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000047 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000047 dacts:ont00000019)

# Class: dacts:ont00000048 (Will Executor Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000048 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000048 "https://www.law.cornell.edu/wex/executor"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000048 "Will Executor Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000048 "A Deontic Role that inheres in an Agent and is realized in administering a decedent's estate in accordance with a will and applicable law."@en)
AnnotationAssertion(skos:example dacts:ont00000048 "The role of a person named in a will to pay the decedent's debts and distribute assets."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000048 "Use this class for the office or role of the executor, not for the person as a human being independently of the estate-administration context."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000048 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000048 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000048 dacts:ont00000004)

# Class: dacts:ont00000049 (Will and Testament Content)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000049 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000049 "https://www.law.cornell.edu/wex/last_will_and_testament"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000049 "Will and Testament Content"@en)
AnnotationAssertion(skos:definition dacts:ont00000049 "A Document Act Input Document that specifies how a testator's assets or estate is to be managed or distributed after the testator's death."@en)
AnnotationAssertion(skos:example dacts:ont00000049 "The clauses in a will directing that a house be sold and the proceeds divided among named children."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000049 "Use this class for the directive content borne by a will, not for the signed paper or electronic artifact that bears that content."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000049 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000049 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000049 dacts:ont00000001)

# Class: dacts:ont00000050 (Heir Designation Content)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000050 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000050 "https://www.law.cornell.edu/wex/heir"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000050 "Heir Designation Content"@en)
AnnotationAssertion(skos:definition dacts:ont00000050 "A Designative Information Content Entity that designates one or more agents as intended recipients of estate assets, responsibilities, or related succession statuses."@en)
AnnotationAssertion(skos:example dacts:ont00000050 "A clause naming a daughter as the recipient of a family residence under a will."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000050 "Use this class for the designating content within a succession instrument; the fuller will content may include additional directive clauses beyond designation."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000050 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000050 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000050 cco2:ont00000686)

# Class: dacts:ont00000051 (Estate Document)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000051 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000051 "https://www.law.cornell.edu/wex/will"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000051 "Estate Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000051 "A Document Act Input Document that bears information intended to govern the management, transfer, or administration of a person's estate or related affairs."@en)
AnnotationAssertion(skos:example dacts:ont00000051 "A will, codicil, or trust amendment prepared for execution as part of estate planning."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000051 "Use this class as a broad estate-planning document category; more specific subclasses can distinguish wills, trusts, powers of attorney, and related instruments."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000051 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000051 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000051 dacts:ont00000001)

# Class: dacts:ont00000052 (Legal Attorney Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000052 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000052 "https://www.law.cornell.edu/wex/attorney"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000052 "Legal Attorney Role"@en)
AnnotationAssertion(skos:altLabel dacts:ont00000052 "Attorney-at-Law Role"@en)
AnnotationAssertion(skos:altLabel dacts:ont00000052 "Lawyer Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000052 "A Deontic Role that inheres in an Agent authorized to practice law and is realized in representing, advising, or appearing for clients in legal matters."@en)
AnnotationAssertion(skos:example dacts:ont00000052 "A licensed attorney advises a client about litigation risk and files motions on the client's behalf."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000052 "Use this class for the professional legal role of an attorney at law, not for an attorney-in-fact created by an ordinary power of attorney."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000052 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000052 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000052 dacts:ont00000004)

# Class: dacts:ont00000053 (Legal Party Proxy Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000053 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000053 "https://www.law.cornell.edu/wex/power_of_attorney"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000053 "Legal Party Proxy Role"@en)
AnnotationAssertion(skos:altLabel dacts:ont00000053 "Legal Client Representative Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000053 "A Deontic Role that inheres in an Agent and is realized in acting on behalf of a legal party under delegated or institutionally recognized authority."@en)
AnnotationAssertion(skos:example dacts:ont00000053 "A guardian signs a filing on behalf of a minor ward in a probate matter."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000053 "Use this class for proxy or representative authority in legal matters generally, whether or not the bearer is a licensed attorney."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000053 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000053 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000053 dacts:ont00000004)

# Class: dacts:ont00000054 (Legal Advisor Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000054 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000054 "https://www.law.cornell.edu/wex/lawyer"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000054 "Legal Advisor Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000054 "A Deontic Role that inheres in an Agent and is realized in communicating advice about legal rights, duties, procedures, or consequences to another agent."@en)
AnnotationAssertion(skos:example dacts:ont00000054 "In-house counsel advises a company officer about reporting obligations under a regulation."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000054 "Use this class for advisory functions specifically about legal matters; broader strategic, financial, or policy advising belongs elsewhere."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000054 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000054 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000054 dacts:ont00000004)

# Class: dacts:ont00000055 (Attorney of Record Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000055 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000055 "https://www.law.cornell.edu/wex/represent"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000055 "Attorney of Record Role"@en)
AnnotationAssertion(skos:altLabel dacts:ont00000055 "Counsel of Record Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000055 "A Legal Attorney Role that inheres in an Agent and is realized in formally appearing in a legal proceeding on behalf of a represented party."@en)
AnnotationAssertion(skos:example dacts:ont00000055 "The lawyer listed on the docket as counsel responsible for receiving filings in a civil case."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000055 "Use this class when formal appearance in a specific matter is central; not every legal attorney role is an attorney-of-record role."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000055 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000055 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000055 dacts:ont00000052)

# Class: dacts:ont00000056 (Lawyer License Document)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000056 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000056 "https://www.law.cornell.edu/wex/admission_to_practice"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000056 "Lawyer License Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000056 "An Identification Artifact that bears information evidencing that some agent has been admitted or authorized to practice law within a jurisdiction."@en)
AnnotationAssertion(skos:example dacts:ont00000056 "A certificate of admission to the bar issued by a state supreme court."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000056 "Use this class for the document evidencing legal licensure or admission, not for the licensure process or the attorney role borne by its subject."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000056 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000056 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000056 dacts:ont00000016)

# Class: dacts:ont00000057 (Law-degree Recipient Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000057 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000057 "https://www.law.cornell.edu/wex/law_school"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000057 "Law-degree Recipient Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000057 "A Role that inheres in an Agent by virtue of that agent's having been awarded a degree in law by an educational institution."@en)
AnnotationAssertion(skos:example dacts:ont00000057 "The role borne by a person after receiving a Juris Doctor degree."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000057 "Use this class for educational attainment, not for professional licensure to practice law; the latter belongs under legal attorney or licensing classes."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000057 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000057 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000057 obo:BFO_0000023)

# Class: dacts:ont00000058 (Lawyer Licensing Process)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000058 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000058 "https://www.law.cornell.edu/wex/admission_to_practice"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000058 "Lawyer Licensing Process"@en)
AnnotationAssertion(skos:definition dacts:ont00000058 "A Planned Act that evaluates and records whether an applicant satisfies the conditions for admission or authorization to practice law in a jurisdiction."@en)
AnnotationAssertion(skos:example dacts:ont00000058 "A state bar admission workflow including character review, examination results, oath, and license issuance."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000058 "Use this class for the licensing or admission process as a planned social process, not for the resulting license document or attorney role."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000058 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000058 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000058 cco2:ont00000228)

# Class: dacts:ont00000059 (Legal Representation Assignment Process)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000059 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000059 "https://www.law.cornell.edu/wex/represent"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000059 "Legal Representation Assignment Process"@en)
AnnotationAssertion(skos:definition dacts:ont00000059 "A Planned Act that establishes or records that a legal attorney or other proxy is authorized to represent a party in a specified legal matter."@en)
AnnotationAssertion(skos:example dacts:ont00000059 "A client signs an engagement agreement and notice of appearance authorizing counsel to act in a lawsuit."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000059 "Use this class for the process that assigns or records representational authority, not for the attorney-client relationship considered as a continuing social arrangement."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000059 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000059 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000059 cco2:ont00000228)

# Class: dacts:ont00000060 (Legal Representation Declaration Document)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000060 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000060 "https://www.law.cornell.edu/wex/represent"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000060 "Legal Representation Declaration Document"@en)
AnnotationAssertion(skos:definition dacts:ont00000060 "A Document Act Input Document that is prepared to be executed in a document act establishing or recording an assignment of legal representation."@en)
AnnotationAssertion(skos:example dacts:ont00000060 "A signed notice of appearance or retainer agreement submitted to a tribunal or client file."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000060 "Use this class for the document used to establish or document representation; a filed copy in the court record may warrant further specialization."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000060 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000060 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000060 dacts:ont00000001)

# Class: dacts:ont00000061 (Fiduciary Negotiation Process)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000061 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000061 "https://www.law.cornell.edu/wex/fiduciary_duty"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000061 "Fiduciary Negotiation Process"@en)
AnnotationAssertion(skos:definition dacts:ont00000061 "A Planned Act in which one or more agents negotiate terms while at least one participant bears fiduciary duties toward another party."@en)
AnnotationAssertion(skos:example dacts:ont00000061 "Trustees negotiate the terms of an investment-management agreement on behalf of beneficiaries."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000061 "Use this class when fiduciary obligations shape the negotiation's normative structure; ordinary arms-length bargaining does not suffice."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000061 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000061 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000061 cco2:ont00000228)

# Class: dacts:ont00000062 (Employment Contract Negotiation Process)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000062 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000062 "https://www.law.cornell.edu/wex/bilateral_contract"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000062 "Employment Contract Negotiation Process"@en)
AnnotationAssertion(skos:definition dacts:ont00000062 "A Planned Act in which prospective or existing parties negotiate the terms of an employment contract."@en)
AnnotationAssertion(skos:example dacts:ont00000062 "A candidate and employer negotiate salary, duties, and non-disclosure terms before signing an offer letter."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000062 "Use this class for the negotiation process leading toward an employment agreement, not for the employment relation after the contract takes effect."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000062 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000062 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000062 cco2:ont00000228)

# Class: dacts:ont00000063 (Legal Filing Process)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000063 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000063 "https://www.law.cornell.edu/wex/plead"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000063 "Legal Filing Process"@en)
AnnotationAssertion(skos:definition dacts:ont00000063 "A Legal System Act that places a legal document into the official record of a court or other legal authority."@en)
AnnotationAssertion(skos:example dacts:ont00000063 "An attorney electronically files a complaint with a trial court clerk."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000063 "Use this class for the act of formally filing, not for drafting the underlying document or for later adjudicative steps triggered by the filing."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000063 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000063 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000063 cco2:ont00001314)

# Class: dacts:ont00000064 (Personal Custodian Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000064 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000064 "https://www.law.cornell.edu/index.php/wex/personal_guardian"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000064 "Personal Custodian Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000064 "A Role that inheres in an Agent and is realized in managing some person's personal affairs under a socially or legally recognized custodial arrangement."@en)
AnnotationAssertion(skos:example dacts:ont00000064 "A court-appointed custodian decides where an incapacitated adult will receive daily care."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000064 "Use this class for custodial responsibility over personal affairs; if the role is specifically created by a formal guardianship order, Legal Guardian Role may be more precise."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000064 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000064 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000064 obo:BFO_0000023)

# Class: dacts:ont00000065 (Legal Guardian Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000065 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000065 "https://www.law.cornell.edu/wex/guardian"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000065 "Legal Guardian Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000065 "A Role that has as a proper part some Deontic Role, inheres in an Agent, and is realized in caring for, deciding for, or controlling the affairs of a ward under a legally recognized guardianship."@en)
AnnotationAssertion(skos:example dacts:ont00000065 "A guardian appointed by a probate court to make medical and residential decisions for an incapacitated adult."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000065 "Use this class for roles constituted by law or court order; broader caregiving roles without formal legal standing do not belong here."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000065 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000065 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000065 obo:BFO_0000023)

# Class: dacts:ont00000066 (Social Group)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000066 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000066 "https://plato.stanford.edu/archives/spr2024/entries/social-ontology/"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000066 "Social Group"@en)
AnnotationAssertion(skos:definition dacts:ont00000066 "A Group of Persons whose members stand in socially recognized relations of membership, participation, or common practice."@en)
AnnotationAssertion(skos:example dacts:ont00000066 "A court, parish, club, guild, or professional association considered as a group of persons."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000066 "Use this class for groups constituted or sustained by social relations or practices; merely spatial aggregates of people without relevant social organization do not qualify."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000066 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000066 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000066 cco2:ont00000914)

# Class: dacts:ont00000067 (Privacy Entitlement Role)

AnnotationAssertion(obo:IAO_0000114 dacts:ont00000067 obo:IAO_0000120)
AnnotationAssertion(dcterms:bibliographicCitation dacts:ont00000067 "https://www.law.cornell.edu/wex/right_to_privacy"^^xsd:anyURI)
AnnotationAssertion(rdfs:label dacts:ont00000067 "Privacy Entitlement Role"@en)
AnnotationAssertion(skos:definition dacts:ont00000067 "A Deontic Role that inheres in an Agent and entitles its bearer to restrict or control access to information, spaces, bodily states, or activities concerning that bearer."@en)
AnnotationAssertion(skos:example dacts:ont00000067 "A patient's role of controlling who may access the patient's protected health information."@en)
AnnotationAssertion(skos:scopeNote dacts:ont00000067 "Use this class for normatively grounded privacy entitlements, not merely for factual secrecy or inaccessibility lacking any right-like structure."@en)
AnnotationAssertion(cco2:ont00001760 dacts:ont00000067 "https://github.com/jonathanvajda/cco-d-acts"^^xsd:anyURI)
AnnotationAssertion(cco2:ont00001762 dacts:ont00000067 "Jonathan M. Vajda"@en)
SubClassOf(dacts:ont00000067 dacts:ont00000004)


)