AnnotationAssertion(<http://purl.obolibrary.org/obo/has_curation_status> <https://github.com/jonathanvajda/cco-d-acts/ont00000022> "metadata incomplete")
AnnotationAssertion(rdfs:label <https://github.com/jonathanvajda/cco-d-acts/ont00000022> "is responsible for"@en)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://github.com/jonathanvajda/cco-d-acts/ont00000022> "x is responsible for y iff ..."@en)
