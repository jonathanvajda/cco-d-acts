# Captures: If Agent A is an Obligor Role (?obRole) bearer and Agent B is normatively responsible for tracking it, Agent B is inferred to be the Obligee Role (?eeRole) bearer.
[ rdf:type swrl:Imp ;
  swrl:body (
    [ rdf:type swrl:ClassAtom ; swrl:classPredicate dacts:ont00000029 ; swrl:argument1 :obRole ]
    [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate obo:BFO_0000052 ; swrl:argument1 :obRole ; swrl:argument2 :agentA ]
    [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate dacts:ont00000022 ; swrl:argument1 :agentB ; swrl:argument2 :obRole ]
  ) ;
  swrl:head (
    [ rdf:type swrl:ClassAtom ; swrl:classPredicate dacts:ont00000030 ; swrl:argument1 :eeRole ]
    [ rdf:type swrl:IndividualPropertyAtom ; swrl:propertyPredicate obo:BFO_0000052 ; swrl:argument1 :eeRole ; swrl:argument2 :agentB ]
  )
] .

